 * Ported from HZHY kernel-6.1 SDK to mainline Linux 7.1 / OpenWrt.
 */

#include "rk3506.dtsi"

/ {
	model = "HZ-RK3506SP_MiniEVM";
	compatible = "rockchip,rk3506-evb1-v10", "rockchip,rk3506";

	/* The vendor OP-TEE/secure monitor does not implement the PSCI 1.0
	 * SMC interface advertised by the initial rk3506.dtsi. Linux probes
	 * PSCI_VERSION (SMC 0x84000000) during setup_arch() and never returns.
	 * Boot as a single-core system until a matching secure firmware or a
	 * native RK3506 SMP enable method is available. */
	/delete-node/ psci;

	aliases {
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
		ethernet0 = &gmac0;
		ethernet1 = &gmac1;
		i2c0 = &i2c0;
		i2c2 = &i2c2;
	};

	chosen {
		stdout-path = &uart0;
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x20000000>;
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		/* OP-TEE / trust resident memory.
		 * The SPL/loader pins OP-TEE in low DRAM [0x0, ~0x62000).
		 * Without this carve-out the kernel adds those pages to the
		 * free pool and hands them to user space; the secure world
		 * then rejects the access as a precise external abort.
		 * Mirrors the vendor rk3506 DT's trust@0 reservation. */
		trust@0 {
			/* OP-TEE reports 0x62000 bytes, but the secure DRAM firewall may
			 * protect low memory at a coarser granularity.  Keep Linux and the
			 * zImage output above the first 2 MiB. */
			reg = <0x0 0x200000>;
		};
	};

	vcc12v_dc: vcc12v-dc {
		compatible = "regulator-fixed";
		regulator-name = "vcc12v_dc";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
	};

	vcc_sys: vcc-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc12v_dc>;
	};

	vcc3v3_stb: vcc3v3-stb {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_stb";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc_sys>;
	};

	vcc_1v8: vcc-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		vin-supply = <&vcc3v3_stb>;
	};

	vcc_3v3: vcc-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc_sys>;
	};

	vccio_sd: vccio-sd-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vccio_sd";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc_sys>;
	};

	vcc5v0_otg0: vcc5v0-otg0-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_otg0";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		enable-active-high;
		gpio = <&gpio1 RK_PA2 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc5v0_otg0_en>;
	};

	vcc5v0_otg1: vcc5v0-otg1-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_otg1";
		regulator-boot-on;
		regulator-always-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		enable-active-high;
		gpio = <&gpio1 RK_PA1 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc5v0_otg1_en>;
	};

	leds: leds {
		compatible = "gpio-leds";
		status = "okay";
		run_led: run-led {
			label = "run";
			gpios = <&gpio1 RK_PA4 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "heartbeat";
			default-state = "on";
		};
	};

};

/* CPU operating points (OPP).
 * Without an OPP table the cpufreq-dt driver has no valid frequency
 * targets; ondemand may attempt to scale the PVTPLL to an undefined
 * rate and hang the system.  These are conservative, clk-only points.
 * If a PMIC-based cpu-supply is added later, append voltage columns. */
&cpu0 {
	/delete-property/ enable-method;
	operating-points = <
		1200000	0	/* 1.2 GHz (stock boot speed) */
		1008000	0	/* 1.008 GHz */
		816000	0	/* 816 MHz */
		600000	0	/* 600 MHz */
		408000	0	/* 408 MHz */
	>;
};

&cpu1 {
	/delete-property/ enable-method;
	status = "disabled";
};

&cpu2 {
	/delete-property/ enable-method;
	status = "disabled";
};

&uart0 {
	status = "okay";
};

&uart1 {
	status = "disabled";
};

&uart2 {
	status = "disabled";
};

&uart3 {
	status = "disabled";
};

&i2c0 {
	status = "disabled";
};

&i2c2 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&rm_io4_i2c2_scl &rm_io5_i2c2_sda>;

	lt8912b: lt8912b@48 {
		compatible = "lontium,lt8912b-hdmi";
		reg = <0x48>;
		reset-gpios = <&gpio1 RK_PA5 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

&sai1 {
	status = "disabled";
};

&spi0 {
	status = "disabled";
	num-cs = <2>;
	pinctrl-names = "default";
	pinctrl-0 = <&rm_io14_spi0_clk &rm_io13_spi0_csn0 &rm_io15_spi0_csn1 &rm_io17_spi0_mosi &rm_io16_spi0_miso>;
	flash@0 {
		compatible = "winbond,w25q20cl", "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
	};
	flash@1 {
		compatible = "winbond,w25q20cl", "jedec,spi-nor";
		reg = <1>;
		spi-max-frequency = <50000000>;
	};
};

&sfc {
	status = "okay";
};

&usb2phy {
	status = "disabled";
};

&u2phy_otg0 {
	status = "disabled";
};

&u2phy_otg1 {
	status = "disabled";
};

&usb20_otg0 {
	status = "disabled";
};

&usb20_otg1 {
	status = "disabled";
};

&gmac0 {
	phy-mode = "rmii";
	clock_in_out = "input";
	snps,reset-gpio = <&gpio1 RK_PB7 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <20000 20000 20000>;
	pinctrl-names = "default";
	pinctrl-0 = <&eth_rmii0_miim_pins &eth_rmii0_tx_bus2_pins &eth_rmii0_rx_bus2_pins &eth_rmii0_clk_pins>;
	phy-handle = <&rmii_phy0>;
	status = "okay";
};

&mdio0 {
	/delete-node/ phy@1;
	rmii_phy0: phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x0>;
	};
};

&gmac1 {
	phy-mode = "rmii";
	clock_in_out = "input";
	snps,reset-gpio = <&gpio0 RK_PD0 GPIO_ACTIVE_HIGH>;
	snps,reset-active-high;
	snps,reset-delays-us = <20000 20000 20000>;
	pinctrl-names = "default";
	pinctrl-0 = <&eth_rmii1_miim_pins &eth_rmii1_tx_bus2_pins &eth_rmii1_rx_bus2_pins &eth_rmii1_clk_pins>;
	phy-handle = <&rmii_phy1>;
	status = "okay";
};

&mdio1 {
	rmii_phy1: phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x0>;
	};
};

&pinctrl {
	headphone {
		hp_det: hp-det {
			rockchip,pins = <1 RK_PA6 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
	usb {
		vcc5v0_otg0_en: vcc5v0-otg0-en {
			rockchip,pins = <1 RK_PA2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		vcc5v0_otg1_en: vcc5v0-otg1-en {
			rockchip,pins = <1 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};
